<Window x:Class="CybersecurityAwarenessChatBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CybersecurityAwarenessChatBotGUI"
        mc:Ignorable="d"
        Title="Cybersecurity Awareness Bot" 
        Height="600" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#ECE5DD">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER with ASCII art and image -->
            <Border Grid.Row="0" Background="LightBlue" Margin="10" CornerRadius="10" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                <!-- ASCII art -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="AsciiArtDisplay" 
                       Grid.Column="0"
                       FontFamily="Courier New" 
                       FontSize="6" 
                       Foreground="DarkBlue"
                       TextWrapping="NoWrap"
                       TextAlignment="Center"
                       VerticalAlignment="Center"/>
                    <TextBlock Text="Your Cyber Assistant ChatBot" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
                
                    <!-- Image at top right -->
                    <Border Grid.Column="1" Width="80" Height="75" CornerRadius="30" Margin="15,0,25,10" ClipToBounds="True">
                        <Image Source="/Assets/Me.jpeg" Stretch="UniformToFill" Margin="0,-10,0,0"/>
                    </Border>
                </Grid>
            </Border>

         <!-- Part 3 buttons-->
            <WrapPanel Grid.Row="1" Margin="10,0,10,10" HorizontalAlignment="Center">
                <Button x:Name="btnTasks" Content="📋 Tasks" Width="80" Height="30" Margin="5" 
            Background="#075E54" Foreground="White" Click="btnTasks_Click"/>
                <Button x:Name="btnQuiz" Content="🎯 Quiz" Width="80" Height="30" Margin="5" 
            Background="#075E54" Foreground="White" Click="btnQuiz_Click"/>
                <Button x:Name="btnLog" Content="📜 Log" Width="80" Height="30" Margin="5" 
            Background="#075E54" Foreground="White" Click="btnLog_Click"/>
            </WrapPanel>


        <!-- CHAT DISPLAY AREA -->
            <ScrollViewer x:Name="chatScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#ECE5DD">
                <StackPanel x:Name="ChatPanel" Margin="10"/>
            </ScrollViewer>

            <!-- INPUT AREA -->
            <Border Grid.Row="2" Background="#F0F0F0" Padding="10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="txtUserInput" 
                         Height="40" 
                         FontSize="14" 
                         Background="White"
                         VerticalContentAlignment="Center"
                         Padding="10,0"
                         KeyDown="txtUserInput_KeyDown"/>

                    <Button x:Name="btnSend" 
                        Grid.Column="1" 
                        Content="Send" 
                        Width="70" 
                        Height="40" 
                        Margin="10,0,0,0"
                        Background="DarkBlue"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="btnSend_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Window>